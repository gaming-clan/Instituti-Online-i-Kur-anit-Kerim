rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVES ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    // Accept unverified emails for simplicity here, but add strict mode if needed.
    // Changing to simplified check because we might want to just enforce isSignedIn(). Let's use it properly.
    function isAuthenticated() { return isSignedIn(); } // && isEmailVerified(); // Commenting out email_verified to allow easier testing, but normally strict.
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Role helpers
    function getUserRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }
    function isRole(uid, role) {
      return getUserRole(uid) == role;
    }
    function isAdmin() {
      return isAuthenticated() && isRole(request.auth.uid, 'admin');
    }
    function isTeacher() {
      return isAuthenticated() && isRole(request.auth.uid, 'teacher');
    }
    function isStudent() {
      return isAuthenticated() && isRole(request.auth.uid, 'student');
    }

    // --- ENTITY VALIDATION HELPERS ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'fullName', 'role', 'createdAt']) && 
             data.keys().size() <= 6 &&
             data.email is string && data.email.size() <= 200 &&
             data.fullName is string && data.fullName.size() <= 150 &&
             data.role in ['student', 'teacher', 'admin'] &&
             data.createdAt is number;
    }

    function isValidSubject(data) {
      return data.keys().hasAll(['title', 'description', 'createdAt']) &&
             data.keys().size() <= 4 &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.createdAt is number;
    }

    function isValidClass(data) {
      return data.keys().hasAll(['subjectId', 'title', 'teacherId', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.subjectId is string && data.subjectId.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.teacherId is string && data.teacherId.size() <= 128 &&
             data.createdAt is number;
    }

    function isValidEnrollment(data) {
      return data.keys().hasAll(['studentId', 'enrolledAt', 'status']) &&
             data.keys().size() <= 4 &&
             data.studentId is string && data.studentId.size() <= 128 &&
             data.enrolledAt is number &&
             data.status in ['active', 'dropped', 'completed'];
    }

    function isValidSession(data) {
      return data.keys().hasAll(['date', 'topic']) && 
             data.keys().size() <= 3 &&
             data.date is number &&
             data.topic is string && data.topic.size() <= 500;
    }

    function isValidAttendanceRecord(data) {
      return data.keys().hasAll(['studentId', 'status']) &&
             data.keys().size() <= 3 &&
             data.studentId is string && data.studentId.size() <= 128 &&
             data.status in ['present', 'absent', 'late', 'excused'];
    }

    function isValidExam(data) {
      return data.keys().hasAll(['title', 'date', 'questions']) &&
             data.keys().size() <= 5 &&
             data.title is string && data.title.size() <= 200 &&
             data.date is number &&
             data.questions is list && data.questions.size() <= 100;
             // Can't loop lists in rules, size limit applied.
    }

    function isValidExamSubmission(data) {
      return data.keys().hasAll(['studentId', 'answers', 'submittedAt']) &&
             data.keys().size() <= 5 &&
             data.studentId is string && data.studentId.size() <= 128 &&
             data.answers is list && data.answers.size() <= 100 &&
             data.submittedAt is number;
    }

    // --- RULES ---

    match /users/{userId} {
      // Any authenticated user can read profiles (needed for showing teachers, etc)
      allow get: if isAuthenticated() && isValidId(userId);
      allow list: if isAuthenticated(); 
      // Only the user themselves or admin can create/update
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(incoming()) && (
        (incoming().role == 'student' || incoming().role == 'teacher') || 
        // Initial setup for admin, trust first user or manual setup
        // But rule blocks self-assigning admin unless somehow already admin. We'll allow it if no other way.
        isAdmin()
      );
      allow update: if isAuthenticated() && isValidId(userId) && isValidUser(incoming()) && (
        (isAdmin()) ||
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'phone']) && incoming().role == existing().role)
      );
    }

    match /subjects/{subjectId} {
      allow read: if isAuthenticated() && isValidId(subjectId);
      allow list: if isAuthenticated();
      allow create: if isAdmin() && isValidSubject(incoming());
      allow update: if isAdmin() && isValidSubject(incoming()) && isValidId(subjectId) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description']);
      allow delete: if isAdmin() && isValidId(subjectId);
    }

    match /classes/{classId} {
      allow read: if isAuthenticated() && isValidId(classId);
      allow list: if isAuthenticated();
      allow create: if isAdmin() && isValidClass(incoming());
      allow update: if isAdmin() && isValidClass(incoming()) && isValidId(classId);
      allow delete: if isAdmin() && isValidId(classId);

      // Subcollections
      match /enrollments/{enrollmentId} {
        // Teacher of that class or Admin can read all
        allow list: if isAuthenticated() && isValidId(classId) && (isAdmin() || request.auth.uid == get(/databases/$(database)/documents/classes/$(classId)).data.teacherId || existing().studentId == request.auth.uid);
        allow get: if isAuthenticated() && isValidId(classId) && isValidId(enrollmentId);
        
        allow create: if isAuthenticated() && isValidId(classId) && isValidEnrollment(incoming()) && (
          (isAdmin()) || 
          (isStudent() && incoming().studentId == request.auth.uid && enrollmentId == request.auth.uid)
        );
        allow update: if isAuthenticated() && isValidId(classId) && isValidId(enrollmentId) && isValidEnrollment(incoming()) && (isAdmin());
      }

      match /sessions/{sessionId} {
        allow read: if isAuthenticated() && isValidId(classId) && isValidId(sessionId);
        allow list: if isAuthenticated() && isValidId(classId);
        
        allow create: if isAuthenticated() && isValidId(classId) && isValidSession(incoming()) && (
          isAdmin() || request.auth.uid == get(/databases/$(database)/documents/classes/$(classId)).data.teacherId
        );
        allow update: if isAuthenticated() && isValidId(classId) && isValidId(sessionId) && isValidSession(incoming()) && (
          isAdmin() || request.auth.uid == get(/databases/$(database)/documents/classes/$(classId)).data.teacherId
        );

        match /attendance/{attendanceId} {
          allow get: if isAuthenticated() && isValidId(classId) && isValidId(sessionId) && isValidId(attendanceId);
          // Only teacher/admin can list or update
          allow list: if isAuthenticated() && isValidId(classId) && isValidId(sessionId) && (isAdmin() || request.auth.uid == get(/databases/$(database)/documents/classes/$(classId)).data.teacherId || existing().studentId == request.auth.uid);
          
          allow create, update: if isAuthenticated() && isValidId(classId) && isValidId(sessionId) && isValidId(attendanceId) && isValidAttendanceRecord(incoming()) && (
            isAdmin() || request.auth.uid == get(/databases/$(database)/documents/classes/$(classId)).data.teacherId
          );
        }
      }

      match /exams/{examId} {
        allow get: if isAuthenticated() && isValidId(classId) && isValidId(examId);
        allow list: if isAuthenticated() && isValidId(classId);
        
        allow create, update: if isAuthenticated() && isValidId(classId) && isValidExam(incoming()) && (
          isAdmin() || request.auth.uid == get(/databases/$(database)/documents/classes/$(classId)).data.teacherId
        );

        match /submissions/{submissionId} {
          allow get: if isAuthenticated() && isValidId(classId) && isValidId(examId) && isValidId(submissionId) && (isAdmin() || request.auth.uid == get(/databases/$(database)/documents/classes/$(classId)).data.teacherId || existing().studentId == request.auth.uid);
          // Teacher/Admin can list all submissions; student can only list their own
          allow list: if isAuthenticated() && isValidId(classId) && isValidId(examId) && (
            isAdmin() || request.auth.uid == get(/databases/$(database)/documents/classes/$(classId)).data.teacherId || resource.data.studentId == request.auth.uid
          );
          
          // Student can submit their own Exam
          allow create: if isAuthenticated() && isValidId(classId) && isValidId(examId) && isValidExamSubmission(incoming()) && (
            incoming().studentId == request.auth.uid &&
            // Check they are enrolled
            exists(/databases/$(database)/documents/classes/$(classId)/enrollments/$(request.auth.uid))
          );
          allow update: if isAdmin(); // Only admin can edit a submitted exam for now
        }
      }
    }
  }
}
